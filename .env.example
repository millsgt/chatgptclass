# Copy this file to .env and fill in your own values. NEVER commit .env.
# The .gitignore in this repo excludes .env so your real keys stay local.

# OpenAI (chatgpt demos under demos/chatgpt/ and apps/flask-chat/)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Azure OpenAI (only for the Azure demos in demos/chatgpt/api-examples/)
# Endpoint looks like https://your-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-key-here
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# GitHub (only if you point the GitHub MCP server at a PAT for the Segment 4 demo)
# Fine-grained token: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=github_pat_your-token-here
